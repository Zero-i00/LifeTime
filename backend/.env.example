
# Base
POST=8080
HOST=0.0.0.0
NAME="Life Time API"
# DEV or PROD
MODE=DEV

# Database
POSTGRES_DB=lifetime_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=12345678
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Auth
AUTH_SECRET_KEY=secret
AUTH_ALGORITHM=RS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=15
AUTH_REFRESH_TOKEN_EXPIRE_DAYS=30

#S3
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_LINK_STATISTIC_BUCKET=link-statistic-bucket-1
S3_ENDPOINT_URL=https://s3.ru-3.storage.selcloud.ru

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Worker
WORKER_CHECK_INTERVAL_SECONDS=300
WORKER_REQUEST_TIMEOUT_SECONDS=10
WORKER_MAX_CONCURRENT_CHECKS=20